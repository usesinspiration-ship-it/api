PORT=3000
NODE_ENV=development
DB_HOST=localhost
DB_PORT=3306
DB_USER=cv_vault_user
DB_PASS=password
DB_NAME=cv_vault_db
DB_POOL_SIZE=10
DB_SSL=false
JWT_SECRET=your_secret_key
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
API_URL=http://localhost:3000
UPLOAD_MAX_MB=50
UPLOAD_MIN_KB=1
ENABLE_CLAMAV_SCAN=false
CLAMAV_COMMAND=clamscan
UPLOAD_PROCESS_TIMEOUT_MS=30000
CLAMAV_TIMEOUT_MS=12000
RESET_TOKEN_EXPIRES_MINUTES=60
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@cv-vault.local
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=100
AUTH_SENSITIVE_WINDOW_MS=900000
AUTH_SENSITIVE_MAX=15
STATS_CACHE_TTL_MS=3600000
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=10M
LOG_MAX_FILES=30
DEBUG=false
LOG_EXTERNAL_WEBHOOK=
